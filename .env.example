# Copy this file to .env and fill in your key.
# Never commit .env to git — add it to .gitignore.
#
# The python-dotenv library loads this automatically when you call
# load_dotenv() in your code. This is standard practice for managing
# secrets in Python projects without hardcoding them.

ANTHROPIC_API_KEY=your_api_key_here

# Optional: override the model used for specialist agents.
# Sonnet is the right choice here — fast enough for research tasks,
# capable enough for structured JSON output with web search.
# Opus would be overkill and expensive for 6 concurrent agents.
RESEARCH_MODEL=claude-sonnet-4-5

# Optional: override the model used for the final synthesis step.
# Synthesis requires more reasoning about cross-agent conflicts,
# so Opus is a reasonable upgrade here if budget allows.
SYNTHESIS_MODEL=claude-sonnet-4-5
